# Google Gemini API key (free tier: https://aistudio.google.com/apikey)
# Get your key, then copy this file to .env and paste the key.
GOOGLE_API_KEY=your_gemini_api_key_here

# Application settings
APP_ENV=development
LOG_LEVEL=INFO

# Optional: which Gemini model to use
# gemini-2.0-flash-exp = fastest, free, vision-capable (RECOMMENDED)
# gemini-1.5-flash    = stable, free, vision-capable
# gemini-1.5-pro      = best quality, slower, free with low rate limits
GEMINI_MODEL=gemini-2.0-flash-exp
